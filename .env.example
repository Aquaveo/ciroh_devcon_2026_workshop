# TethysDash MCP Workshop — environment template.
#
# Copy this to .env and fill in concrete values BEFORE running setup.sh.
# .env is gitignored; .env.example is committed.
#
# Maintainer pins these in docs/pre-conditions.md and keeps the two files
# in sync per event tag. Participants generally do not edit this file —
# they copy it to .env and adjust VM_HOST if they want the tunnel.sh
# helper to remember their VM.

# ---- Repo SHA pins (Unit 0 Q7 + Q7b) --------------------------------------
# 40-char commit SHAs on the two consumed repos. setup.sh runs
# `git checkout $SHA` after clone. Detached HEAD is expected for participants.
TETHYSDASH_SHA=TBD
NRDS_MCPS_SHA=TBD

# ---- Image tags (per-event publish) ---------------------------------------
# The workshop maintainer publishes ghcr.io/aquaveo/tethysdash-workshop:<tag>
# from this repo's publish-image.yml workflow before the event. Set IMAGE_TAG
# to the published tag for the current event (e.g., v2026-summit). Avoid
# :latest in participant config to keep the cohort on a deterministic image.
IMAGE_TAG=v2026-summit

# The nrds-mcps image is published by the upstream nrds_mcps repo's own
# release pipeline (not by this workshop). Pin to a specific tag for the event.
NRDS_MCPS_IMAGE_TAG=TBD

# ---- tunnel.sh convenience ------------------------------------------------
# Optional. If set, tunnel.sh skips the interactive prompt and uses this host.
# Format: "<user>@<vm-host>" e.g. "ttalbot@workshop-vm-12.access.example.org"
# Leave blank to make tunnel.sh prompt at runtime.
VM_HOST=
